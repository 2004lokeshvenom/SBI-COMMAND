generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  password_hash String?
  exam_date     DateTime?
  daily_hours   Int       @default(6)
  settings      String?
  created_at    DateTime  @default(now())

  progress      TopicProgress[]
  revisions     RevisionSchedule[]
  sessions      StudySession[]
  mock_tests    MockTest[]
  check_ins     DailyCheckIn[]
  xp_events     XPEvent[]
  achievements  Achievement[]
  notifications NotificationLog[]
  notes         Note[]
  states        UserState[]
}

model UserState {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  user_id String @db.ObjectId
  key     String
  value   String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, key])
}

model Subject {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  code     String    @unique
  color    String
  icon     String
  chapters Chapter[]
}

model Chapter {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  subject_id  String  @db.ObjectId
  name        String
  order_index Int
  subject     Subject @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  topics      Topic[]
}

model Topic {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  chapter_id      String  @db.ObjectId
  name            String
  description     String?
  phase           Int
  week_number     Int
  estimated_hours Float
  priority        String  @default("medium")
  exam_type       String  @default("both")
  chapter         Chapter @relation(fields: [chapter_id], references: [id], onDelete: Cascade)

  progress  TopicProgress[]
  revisions RevisionSchedule[]
  sessions  StudySession[]
}

model TopicProgress {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id          String    @db.ObjectId
  topic_id         String    @db.ObjectId
  status           String    @default("not_started")
  confidence       Int       @default(0)
  first_studied_at DateTime?
  last_studied_at  DateTime?
  times_revised    Int       @default(0)
  notes_content    String?
  notes_type       String?

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topic_id], references: [id], onDelete: Cascade)

  @@unique([user_id, topic_id])
}

model RevisionSchedule {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id          String    @db.ObjectId
  topic_id         String    @db.ObjectId
  next_review_date DateTime
  ease_factor      Float     @default(2.5)
  interval_days    Int       @default(1)
  repetition_count Int       @default(0)
  last_reviewed_at DateTime?

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topic_id], references: [id], onDelete: Cascade)

  @@unique([user_id, topic_id])
}

model StudySession {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id             String    @db.ObjectId
  topic_id            String?   @db.ObjectId
  started_at          DateTime  @default(now())
  ended_at            DateTime?
  duration_minutes    Int       @default(0)
  session_type        String    @default("deep_work")
  questions_attempted Int       @default(0)
  questions_correct   Int       @default(0)

  user  User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  topic Topic? @relation(fields: [topic_id], references: [id], onDelete: SetNull)
}

model MockTest {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id            String   @db.ObjectId
  test_name          String
  test_type          String
  date_taken         DateTime @default(now())
  total_marks        Float
  scored_marks       Float
  time_taken_minutes Int
  qa_score           Float?
  reasoning_score    Float?
  english_score      Float?
  ga_score           Float?
  computer_score     Float?
  accuracy_percent   Float
  notes              String?
  created_at         DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model DailyCheckIn {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id           String   @db.ObjectId
  date              String
  type              String
  energy_level      Int?
  mood              String?
  affirmation       String?
  reflection        String?
  hours_planned     Float?
  hours_actual      Float?
  topics_planned    String?
  topics_completed  String?
  difficulty_rating String?
  completed_at      DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, date, type])
}

model XPEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id     String   @db.ObjectId
  event_type  String
  xp_awarded  Int
  description String?
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Achievement {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id          String    @db.ObjectId
  achievement_code String
  unlocked_at      DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, achievement_code])
}

model NotificationLog {
  id      String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id String    @db.ObjectId
  type    String
  message String
  sent_at DateTime  @default(now())
  read_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Note {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String    @db.ObjectId
  title      String
  category   String
  content    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
