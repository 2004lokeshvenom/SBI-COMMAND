# MongoDB connection string (include database name before ?):
# mongodb+srv://USER:PASSWORD@cluster.example.net/YOUR_DB_NAME?retryWrites=true&w=majority
DATABASE_URL=

# Comma-separated allowed browser origins for CORS (your Vercel/Render frontend URL).
# Example: https://sbi-command.onrender.com
FRONTEND_ORIGIN=http://localhost:3000

PORT=5000
